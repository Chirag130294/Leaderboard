            document.getElementById('kt-record-btn').disabled = !(KT.state.win && KT.state.trump.length && KT.state.opp.length);

            let s={}, g={}, w={};
            KT.state.players.forEach(p => { s[p]=0; g[p]=0; w[p]=0; });
            KT.state.history.filter(x=>x.status==='active').forEach(r => {
                r.t.forEach(p => { g[p]++; if(r.w==='trump'){ s[p]+=r.s; w[p]++; } });
