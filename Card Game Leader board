    const APP = {
        currentModule: null,
        switchTab: (tab) => {
            document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-btn, .desktop-nav button').forEach(el => el.classList.remove('active'));
            document.getElementById(`view-${tab}`).classList.add('active');
            
            // Sync mobile and desktop navs
            document.querySelectorAll(`.nav-btn:nth-child(${tab==='setup'?1:tab==='kachuful'?2:tab==='kalitiri'?3:tab==='rules'?4:5})`).forEach(el => el.classList.add('active'));
            document.querySelectorAll(`#dnav-${tab}`).forEach(el => el.classList.add('active'));
            
            if(tab === 'setup') APP.renderSavedPlayers();
            
            let title = "Command Center";
            if(tab === 'kachuful') title = "Kachuful";
            if(tab === 'kalitiri') title = "Kali Tiri";
            if(tab === 'endgame') title = "Results";
            document.getElementById('top-title').innerText = title;
        },
        renderSavedPlayers: () => {
            const saved = Utils.loadSavedPlayers();
            const container = document.getElementById('saved-players-container');
            const list = document.getElementById('saved-players-list');
            if(saved.length > 0) {
                container.style.display = 'block';
                list.innerHTML = saved.map(p => `<button class="pill" onclick="APP.appendPlayer('${p}')">+ ${p}</button>`).join('');
            }
        },
        appendPlayer: (name) => {
            const input = document.getElementById('setup-input');
            input.value = input.value ? input.value + ' ' + name : name;
        },
        initGame: (type) => {
            let names = Utils.parseNames(document.getElementById('setup-input').value);
            
            // --- DUPLICATE CHECK LOGIC ---
            let counts = {};
            let duplicates = [];
            names.forEach(n => {
                counts[n] = (counts[n] || 0) + 1;
                if (counts[n] === 2) duplicates.push(n);
            });

            if (duplicates.length > 0) {
                let keep = confirm(`Duplicate name(s) found: ${duplicates.join(', ')}.\n\nDo you want to keep them?\n(OK = Keep and add numbers, Cancel = Remove duplicates)`);
                let finalNames = [];
                if (keep) {
                    let seen = {};
                    names.forEach(n => {
                        if (seen[n]) {
                            seen[n]++;
                            finalNames.push(`${n} ${seen[n]}`);
                        } else {
                            seen[n] = 1;
                            finalNames.push(n);
                        }
                    });
                } else {
                    finalNames = [...new Set(names)];
                }
                names = finalNames;
            }

            if(names.length < 2) return alert("Enter at least 2 players.");
            
            Utils.savePlayer(names);
            APP.currentModule = type;
            
            if(type === 'kachuful') KF.start(names);
            else KT.start(names);
            
            APP.switchTab(type);
        },
        showEndGame: () => {
            if(!APP.currentModule) return alert("No active game to finish.");
            
            let html = '';
            if(APP.currentModule === 'kachuful') {
                document.getElementById('endgame-title').innerText = "KACHUFUL MATCH";
                const sorted = [...KF.state.players].sort((a,b)=>b.score-a.score);
                sorted.forEach((p, i) => {
                    let medal = i===0?'🥇':(i===1?'🥈':(i===2?'🥉':`#${i+1}`));
                    html += `<div class="rank-row ${i===0?'first':''}">
                        <div style="font-weight:800; font-size:1rem;">${medal} ${p.name}</div>
                        <div style="font-weight:800; font-size:1.1rem; color:var(--gold);">${p.score}</div>
                    </div>`;
                });
            } else {
                document.getElementById('endgame-title').innerText = "KALI TIRI MATCH";
                let s={}; KT.state.players.forEach(p=>s[p]=0);
                KT.state.history.filter(x=>x.status==='active').forEach(r => {
                    r.t.forEach(p => { if(r.w==='trump') s[p]+=r.s; });
                    r.o.forEach(p => { if(r.w==='opp') s[p]+=(r.s*2); });
                });
                const sorted = [...KT.state.players].sort((a,b)=>s[b]-s[a]);
                sorted.forEach((p, i) => {
                    let medal = i===0?'🥇':(i===1?'🥈':(i===2?'🥉':`#${i+1}`));
                    html += `<div class="rank-row ${i===0?'first':''}">
                        <div style="font-weight:800; font-size:1rem;">${medal} ${p}</div>
                        <div style="font-weight:800; font-size:1.1rem; color:var(--gold);">${s[p]}</div>
                    </div>`;
                });
            }
            
            document.getElementById('endgame-results').innerHTML = html;
            APP.switchTab('endgame');
        },
        eraseAll: () => {
            const pin = prompt("Enter PIN to wipe all data:");
            if(pin === "1111") { localStorage.clear(); location.reload(); }
            else if(pin) alert("Incorrect PIN");
        }
    };

    const MODAL = {
        type: null, editIndex: null, state: {},
        open: (type, index) => {
            MODAL.type = type; MODAL.editIndex = index;
            const el = document.getElementById('edit-modal');
            el.classList.add('active');
            
            if(type === 'kf') {
                const rec = KF.state.history[index];
                MODAL.state = { bids: [], misses: [] };
                KF.state.original.forEach((n, i) => {
                    const d = rec.data[n] || {b:0, made:true};
                    MODAL.state.bids[i] = d.b; MODAL.state.misses[i] = !d.made;
                });
                MODAL.renderKFEdit(rec.round);
            } else {
                const rec = KT.state.history[index];
                MODAL.state = { trump: [...rec.t], opp: [...rec.o], score: rec.s, win: rec.w };
                MODAL.renderKTEdit();
            }
        },
        close: () => { document.getElementById('edit-modal').classList.remove('active'); },
        
        renderKFEdit: (round) => {
            const max = KF.calcCards(round);
            let html = '';
            KF.state.original.forEach((n, i) => {
                const statusStr = MODAL.state.misses[i] ? 'Missed' : 'Made';
                const statusCls = MODAL.state.misses[i] ? 'kf-pill-miss' : 'kf-pill-made';
                html += `
                <div class="kf-player-row">
                    <div style="font-weight:600; width:28%; overflow:hidden; text-overflow:ellipsis; font-size:0.85rem;">${n}</div>
                    <div class="stepper">
                        <button class="btn-minus" onclick="MODAL.adjKFBid(${i}, -1, ${max})">−</button>
                        <input readonly value="${MODAL.state.bids[i]}">
                        <button class="btn-plus" onclick="MODAL.adjKFBid(${i}, 1, ${max})">+</button>
                    </div>
                    <button class="kf-pill-status ${statusCls}" style="width:75px; font-size:0.75rem;" onclick="MODAL.togKFMiss(${i})">${statusStr}</button>
                </div>`;
            });
            document.getElementById('edit-modal-body').innerHTML = html;
        },
        adjKFBid: (i, d, max) => { MODAL.state.bids[i] = Math.max(0, Math.min(max, MODAL.state.bids[i] + d)); MODAL.renderKFEdit(KF.state.history[MODAL.editIndex].round); },
        togKFMiss: (i) => { MODAL.state.misses[i] = !MODAL.state.misses[i]; MODAL.renderKFEdit(KF.state.history[MODAL.editIndex].round); },
        
        renderKTEdit: () => {
            let html = `<div class="pill-container">`;
            KT.state.players.forEach(p => {
                const cls = MODAL.state.trump.includes(p) ? 'pill active-trump' : 'pill';
                html += `<button class="${cls}" onclick="MODAL.togKTTeam('${p}')">${p}</button>`;
            });
            html += `</div>
            <div class="multi-stepper" style="margin-top:10px;">
                <div class="btn-group red">
                    <button onclick="MODAL.adjKTScore(-20)">-20</button>
                    <button onclick="MODAL.adjKTScore(-10)">-10</button>
                    <button onclick="MODAL.adjKTScore(-5)">-5</button>
                </div>
                <input value="${MODAL.state.score}" readonly>
                <div class="btn-group green">
                    <button onclick="MODAL.adjKTScore(5)">+5</button>
                    <button onclick="MODAL.adjKTScore(10)">+10</button>
                    <button onclick="MODAL.adjKTScore(20)">+20</button>
                </div>
            </div>
            <div style="display:flex; gap:10px; margin-top:10px;">
                <button class="btn-ghost ${MODAL.state.win==='trump'?'active-trump':''}" style="flex:1; padding:10px; ${MODAL.state.win==='trump'?'background:var(--blue); color:white;':''}" onclick="MODAL.setKTWin('trump')">Trump</button>
                <button class="btn-ghost ${MODAL.state.win==='opp'?'active-trump':''}" style="flex:1; padding:10px; ${MODAL.state.win==='opp'?'background:var(--red); color:white;':''}" onclick="MODAL.setKTWin('opp')">Opp</button>
            </div>`;
            document.getElementById('edit-modal-body').innerHTML = html;
        },
        togKTTeam: (p) => {
            if(MODAL.state.trump.includes(p)) { MODAL.state.trump = MODAL.state.trump.filter(x=>x!==p); MODAL.state.opp.push(p); }
            else { MODAL.state.trump.push(p); MODAL.state.opp = MODAL.state.opp.filter(x=>x!==p); }
            MODAL.renderKTEdit();
        },
        adjKTScore: (d) => { MODAL.state.score = Math.max(1, MODAL.state.score + d); MODAL.renderKTEdit(); },
        setKTWin: (w) => { MODAL.state.win = w; MODAL.renderKTEdit(); },

        saveEdit: () => {
            if(MODAL.type === 'kf') {
                const old = KF.state.history[MODAL.editIndex];
                KF.state.original.forEach(n => { if(old.data[n]) { let p = KF.state.players.find(x=>x.name===n); if(p) p.score -= old.data[n].pts; }});
                old.status = 'edited';
                let rec = { id: Date.now(), round: old.round, status: 'active', data: {} };
                KF.state.original.forEach((n, i) => {
                    const b = MODAL.state.bids[i], made = !MODAL.state.misses[i], pts = made ? (b === 0 ? 10 : b * 11) : 0;
                    let p = KF.state.players.find(x=>x.name===n); if(p) p.score += pts;
                    rec.data[n] = { b, made, pts };
                });
                KF.state.history.splice(MODAL.editIndex + 1, 0, rec);
                KF.render();
            } else {
                const old = KT.state.history[MODAL.editIndex];
                old.status = 'edited';
                KT.state.history.splice(MODAL.editIndex + 1, 0, {
                    t: [...MODAL.state.trump], o: [...MODAL.state.opp], s: MODAL.state.score, w: MODAL.state.win, status: 'active'
                });
                KT.render();
            }
            MODAL.close();
        }
    };

    const KF = {
        state: { players: [], original: [], max: 5, round: 1, bids: [], misses: [], phase: 'bid', history: [], suits: [{s:'♠',c:'var(--suit-black)'},{s:'♦',c:'var(--suit-red)'},{s:'♣',c:'var(--suit-black)'},{s:'♥',c:'var(--suit-red)'}] },
        
        start: (names) => {
            KF.state.players = names.map(n => ({name: n, score: 0}));
            KF.state.original = [...names];
            KF.state.max = parseInt(document.getElementById('setup-maxcards').value) || 5;
            KF.state.round = 1; KF.state.history = [];
            document.getElementById('kf-placeholder').style.display = 'none';
            document.getElementById('kf-active-game').classList.add('desktop-grid');
            document.getElementById('kf-active-game').style.display = window.innerWidth >= 768 ? 'grid' : 'block';
            KF.initRound();
        },
        calcCards: (r) => r <= KF.state.max ? r : KF.state.max - (r - KF.state.max),
        initRound: () => {
            KF.state.phase = 'bid';
            KF.state.bids = new Array(KF.state.players.length).fill(0);
            KF.state.misses = new Array(KF.state.players.length).fill(false);
            KF.render();
        },
        adjBid: (i, d) => {
            if(KF.state.phase !== 'bid') return;
            KF.state.bids[i] = Math.max(0, Math.min(KF.calcCards(KF.state.round), KF.state.bids[i] + d));
            KF.render();
        },
        togMiss: (i) => { if(KF.state.phase === 'score') { KF.state.misses[i] = !KF.state.misses[i]; KF.render(); } },
        resetRound: () => { KF.state.phase = 'bid'; KF.state.misses.fill(false); KF.render(); },
        handleAction: () => {
            if(KF.state.phase === 'bid') { KF.state.phase = 'score'; KF.render(); }
            else {
                let rec = { id: Date.now(), round: KF.state.round, status: 'active', data: {} };
                KF.state.players.forEach((p, i) => {
                    const b = KF.state.bids[i], made = !KF.state.misses[i], pts = made ? (b === 0 ? 10 : b * 11) : 0;
                    p.score += pts; rec.data[p.name] = { b, made, pts };
                });
                KF.state.history.push(rec);
                KF.state.players.push(KF.state.players.shift());
                KF.state.round++;
                KF.initRound();
            }
        },
        delGame: (idx) => {
            if(confirm("Void this round?")) {
                let rec = KF.state.history[idx];
                KF.state.original.forEach(n => { let p = KF.state.players.find(x=>x.name===n); if(p && rec.data[n]) p.score -= rec.data[n].pts; });
                rec.status = 'deleted'; KF.render();
            }
        },
        render: () => {
            const cards = KF.calcCards(KF.state.round);
            const trump = KF.state.suits[(KF.state.round - 1) % 4];
            
            document.getElementById('kf-round-label').innerText = `Round ${KF.state.round}`;
            document.getElementById('kf-card-symbol').innerText = trump.s;
            document.getElementById('kf-card-symbol').style.color = trump.c;
            document.getElementById('kf-card-count').innerText = `${cards} Card${cards>1?'s':''}`;
            document.getElementById('kf-phase-label').innerText = KF.state.phase === 'bid' ? 'Enter Agreed Bids' : 'Tap pills if missed';

            const pRows = document.getElementById('kf-player-rows');
            pRows.innerHTML = '';
            
            let currTot = KF.state.bids.slice(0, -1).reduce((a,b)=>a+b, 0);
            let restricted = cards - currTot;
            let lastIdx = KF.state.players.length - 1;
            let btn = document.getElementById('kf-action-btn');
            let warn = document.getElementById('kf-warning-msg');

            if (KF.state.phase === 'bid' && restricted >= 0 && restricted <= cards) {
                warn.innerText = `${KF.state.players[lastIdx].name} CANNOT bid ${restricted}`;
                warn.style.display = 'block';
                if (KF.state.bids[lastIdx] === restricted) { btn.disabled = true; btn.innerText = "Invalid Bid"; btn.className = "btn-danger"; }
                else { btn.disabled = false; btn.innerText = "Lock In Bids"; btn.className = "btn-primary"; }
            } else {
                warn.style.display = 'none'; btn.disabled = false;
                if(KF.state.phase === 'bid') { btn.innerText = "Lock In Bids"; btn.className = "btn-primary"; }
                else { btn.innerText = "Record Scores"; btn.className = "btn-green"; }
            }

            KF.state.players.forEach((p, i) => {
                const ctrl = KF.state.phase === 'bid'
                    ? `<div class="stepper"><button class="btn-minus" onclick="KF.adjBid(${i},-1)">−</button><input readonly value="${KF.state.bids[i]}"><button class="btn-plus" onclick="KF.adjBid(${i},1)">+</button></div>`
                    : `<button class="kf-pill-status ${KF.state.misses[i]?'kf-pill-miss':'kf-pill-made'}" onclick="KF.togMiss(${i})">${KF.state.misses[i]?'Missed':'Made'} ${KF.state.bids[i]}</button>`;
                pRows.innerHTML += `<div class="kf-player-row"><div class="kf-player-name">${p.name}</div>${ctrl}</div>`;
            });

            const lb = document.getElementById('kf-leaderboard');
            lb.innerHTML = [...KF.state.players].sort((a,b)=>b.score-a.score).map((p,i) => `<div class="pill"><span style="color:var(--gold); margin-right:4px;">#${i+1}</span> ${p.name}: <strong>${p.score}</strong></div>`).join('');

            const hHead = document.getElementById('kf-history-head');
            hHead.innerHTML = `<tr><th>R</th>${KF.state.original.map(n=>`<th>${n.substring(0,3)}</th>`).join('')}<th>Act</th></tr>`;
            
            const hBody = document.getElementById('kf-history-body');
            hBody.innerHTML = '';
            [...KF.state.history].reverse().forEach((g, idx) => {
                const rIdx = KF.state.history.length - 1 - idx;
                let tr = `<tr class="${g.status==='deleted'?'struck':''}"><td>${g.round}</td>`;
                KF.state.original.forEach(n => {
                    let d = g.data[n];
                    tr += d ? `<td class="${d.made?'score-made':'score-miss'}">${d.b}${d.made?'✓':'✗'}<br><span class="tiny" style="color:var(--text-muted);">+${d.pts}</span></td>` : `<td>-</td>`;
                });
                tr += `<td>${g.status==='active' ? `<button class="btn-ghost" style="color:var(--gold); margin-bottom:4px; padding:2px 6px;" onclick="MODAL.open('kf', ${rIdx})">✎</button><br><button class="btn-danger" style="padding:2px 6px;" onclick="KF.delGame(${rIdx})">X</button>` : '-'}</td></tr>`;
                hBody.innerHTML += tr;
            });
        }
    };

    const KT = {
