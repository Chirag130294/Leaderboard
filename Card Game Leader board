            });

            document.getElementById('kt-leaderboard').innerHTML = [...KT.state.players].sort((a,b)=>s[b]-s[a]).map(p => {
                return `<tr><td>${p}</td><td style="font-weight:700; color:var(--gold);">${s[p]}</td><td>${g[p]}</td><td>${g[p]?((w[p]/g[p])*100).toFixed(0):0}%</td></tr>`;
            }).join('');

            document.getElementById('kt-history-head').innerHTML = `<tr><th>#</th>${KT.state.players.map(n=>`<th>${n.substring(0,3)}</th>`).join('')}<th>Act</th></tr>`;
            document.getElementById('kt-history-body').innerHTML = KT.state.history.map((r, i) => {
                let tr = `<tr class="${r.status==='deleted'?'struck':''}"><td>${i+1}</td>`;
                KT.state.players.forEach(p => {
                    let scr = "-";
                    if(r.t.includes(p) && r.w==='trump') scr = `<span class="score-made">${r.s}</span>`;
                    if(r.o.includes(p) && r.w==='opp') scr = `<span class="score-made">${r.s*2}</span>`;
                    tr += `<td>${scr}</td>`;
                });
                tr += `<td>${r.status==='active' ? `<button class="btn-ghost" style="color:var(--gold); padding:2px 6px;" onclick="MODAL.open('kt',${i})">✎</button> <button class="btn-danger" style="padding:2px 6px;" onclick="KT.delGame(${i})">X</button>` : '-'}</td></tr>`;
                return tr;
            }).join('');
        }
    };

    window.addEventListener('resize', () => {
        if(APP.currentModule === 'kachuful' && document.getElementById('kf-active-game').style.display !== 'none') {
            document.getElementById('kf-active-game').style.display = window.innerWidth >= 768 ? 'grid' : 'block';
        }
        if(APP.currentModule === 'kalitiri' && document.getElementById('kt-active-game').style.display !== 'none') {
            document.getElementById('kt-active-game').style.display = window.innerWidth >= 768 ? 'grid' : 'block';
        }
    });

    APP.renderSavedPlayers();
    I18N.render();
</script>
</body>
</html>
